---
interface Props {
    links?: Array<{ href: string; label: string }>;
}

const {
    links = [
        { href: "/", label: "Home" },
        { href: "/features", label: "Features" },
        { href: "/pricing", label: "Pricing" },
    ],
} = Astro.props;
---

<header
    class="fixed top-0 left-0 right-0 z-50 bg-background/80 backdrop-blur-md border-b border-muted"
>
    <nav class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-3 group">
            <div class="w-10 h-10 bg-accent flex items-center justify-center">
                <span
                    class="text-background font-black text-xl tracking-tighter"
                    >K</span
                >
            </div>
            <span class="font-black text-xl tracking-tight uppercase"
                >Kilo Code</span
            >
        </a>

        <!-- Desktop Navigation -->
        <ul class="hidden md:flex items-center gap-8">
            {
                links.map((link) => (
                    <li>
                        <a
                            href={link.href}
                            data-astro-prefetch="viewport"
                            class="text-foreground/70 hover:text-foreground transition-colors text-sm font-bold uppercase tracking-wider"
                        >
                            {link.label}
                        </a>
                    </li>
                ))
            }
        </ul>

        <!-- CTA Button (Desktop) -->
        <div class="hidden md:block">
            <a
                href="/pricing"
                data-astro-prefetch="viewport"
                class="inline-flex items-center gap-2 h-12 px-6 bg-accent text-foreground text-sm font-bold uppercase tracking-widest hover:scale-[1.02] active:scale-[0.98] transition-transform"
            >
                Get Started
            </a>
        </div>

        <!-- Mobile Menu Button -->
        <button
            id="mobile-menu-btn"
            class="md:hidden w-10 h-10 flex flex-col items-center justify-center gap-1.5"
            aria-label="Toggle menu"
        >
            <span class="w-6 h-0.5 bg-foreground transition-transform"></span>
            <span class="w-6 h-0.5 bg-foreground transition-opacity"></span>
            <span class="w-6 h-0.5 bg-foreground transition-transform"></span>
        </button>
    </nav>

    <!-- Mobile Menu -->
    <div
        id="mobile-menu"
        class="md:hidden absolute top-full left-0 right-0 bg-background border-b border-muted hidden"
    >
        <ul class="px-6 py-4 flex flex-col gap-4">
            {
                links.map((link) => (
                    <li>
                        <a
                            href={link.href}
                            data-astro-prefetch="viewport"
                            class="block py-3 text-foreground/70 hover:text-foreground transition-colors text-base font-bold uppercase tracking-wider"
                        >
                            {link.label}
                        </a>
                    </li>
                ))
            }
            <li>
                <a
                    href="/pricing"
                    data-astro-prefetch="viewport"
                    class="block py-3 text-accent font-bold uppercase tracking-wider"
                >
                    Get Started
                </a>
            </li>
        </ul>
    </div>
</header>

<script>
    const menuBtn = document.getElementById("mobile-menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");

    menuBtn?.addEventListener("click", () => {
        mobileMenu?.classList.toggle("hidden");

        // Animate hamburger
        const spans = menuBtn.querySelectorAll("span");
        spans[0].classList.toggle("rotate-45");
        spans[0].classList.toggle("translate-y-2");
        spans[1].classList.toggle("opacity-0");
        spans[2].classList.toggle("-rotate-45");
        spans[2].classList.toggle("-translate-y-2");
    });

    // Close menu on link click
    mobileMenu?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
            mobileMenu.classList.add("hidden");
            const spans = menuBtn?.querySelectorAll("span");
            spans?.[0].classList.remove("rotate-45", "translate-y-2");
            spans?.[1].classList.remove("opacity-0");
            spans?.[2].classList.remove("-rotate-45", "-translate-y-2");
        });
    });
</script>
