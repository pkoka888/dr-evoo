# ============================================
# Dr-Evo Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
#
# IMPORTANT: Never commit .env to version control!

# ============================================
# DATABASE
# ============================================
DB_USER=drevo
DB_PASSWORD=change-me-in-production
DB_NAME=drevo_payload

# ============================================
# PAYLOAD CMS
# ============================================
# Generate with: openssl rand -hex 32
PAYLOAD_SECRET=change-me-generate-with-openssl-rand-hex-32

# ============================================
# TRAEFIK / LETS ENCRYPT
# ============================================
LETSENCRYPT_EMAIL=admin@dr-evo.cz

# ============================================
# OPTIONAL: CloudFlare (for DNS challenge)
# ============================================
# CF_EMAIL=your-cloudflare@email.com
# CF_API_KEY=your-cloudflare-api-key

# ============================================
# ASTRO FRONTEND (if using .env in frontend)
# ============================================
# PUBLIC_PAYLOAD_API_URL=https://api.dr-evo.cz/api
# IMGPROXY_URL=https://img.dr-evo.cz

# ============================================
# PAYMENT GATEWAYS (if applicable)
# ============================================
# STRIPE_SECRET_KEY=sk_...
# GOPAY_API_KEY=...